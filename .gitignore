# Compiled binaries and architectures
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries generated by 'go test -c'
*.test

# Output of the go coverage tool, consumed by 'go tool cover'
*.out
*.prof
*.test
cp.out
coverage.txt

# Main compiled binaries (Add your custom binary names here if not matching default patterns)
bin/
dist/
out/

# Go Workspace file (Should not be submitted to version control)
go.work
go.work.sum

# Dependency directories (Only used if you explicitly run 'go mod vendor')
# Most Go developers do not commit vendor/ unless required by specific team workflows.
vendor/

# Local Environment Variables and Secrets
.env
.env.local
.env.*.local

# IDE and Editor specific files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.devcontainer